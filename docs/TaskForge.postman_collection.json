{
  "info": {
    "_postman_id": "a3f5c9d2-8b1e-4f6a-9c2d-taskforgecoll",
    "name": "TaskForge",
    "description": "Full-stack Task Tracker API — auth, RBAC, task CRUD with pagination/filtering, and real-time updates via SignalR. Import the accompanying 'TaskForge Local' environment before running any request.\n\nSuggested run order:\n1. Health Check\n2. Auth > Register (Bootstrap Admin)\n3. Tasks > Get Task Statuses\n4. Tasks > Create Task\n5. Tasks > Get Task By Id\n6. Tasks > List Tasks\n7. Tasks > Update Task\n8. Tasks > Delete Task\n9. Auth > Register (Second User) — then repeat Tasks folder as a standard User to confirm RBAC scoping\n10. Users > List All Users (Admin only)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{healthUrl}}",
              "host": ["{{healthUrl}}"]
            },
            "description": "Confirms the API is running and can reach PostgreSQL. Should return 'Healthy'."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Bootstrap Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "    pm.environment.set('authToken', response.token);",
                  "    console.log('authToken saved. Role:', response.role);",
                  "}",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has a token and role', function () {",
                  "    pm.expect(response).to.have.property('token');",
                  "    pm.expect(response).to.have.property('role');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@taskforge.dev\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "The FIRST user ever registered against a fresh database automatically becomes Admin. Saves the returned token to {{authToken}}."
          },
          "response": []
        },
        {
          "name": "Register (Second User)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "    pm.environment.set('secondAuthToken', response.token);",
                  "    console.log('secondAuthToken saved. Role:', response.role);",
                  "}",
                  "",
                  "pm.test('Second registration gets the User role, not Admin', function () {",
                  "    pm.expect(response.role).to.eql('User');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Standard User\",\n  \"email\": \"user@taskforge.dev\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Any registration after the first becomes a standard User. Saves the token separately to {{secondAuthToken}} so you can test RBAC scoping without overwriting the Admin's token."
          },
          "response": []
        },
        {
          "name": "Register (Duplicate Email - expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 409 Conflict', function () {",
                  "    pm.response.to.have.status(409);",
                  "});",
                  "",
                  "pm.test('Response has a clean error message', function () {",
                  "    const response = pm.response.json();",
                  "    pm.expect(response).to.have.property('error');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@taskforge.dev\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "description": "Demonstrates validation/error handling: re-registering an existing email returns a clean 409, not a raw exception."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "    pm.environment.set('authToken', response.token);",
                  "}",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@taskforge.dev\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Refreshes {{authToken}} for an existing user."
          },
          "response": []
        },
        {
          "name": "Login (Wrong Password - expect 401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 401 Unauthorized', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@taskforge.dev\",\n  \"password\": \"WrongPassword!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Demonstrates a generic, non-revealing error message on invalid credentials — same message whether the email exists or the password is wrong, to prevent account enumeration."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users (Admin only)",
      "item": [
        {
          "name": "List All Users",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "if (Array.isArray(response) && response.length > 0) {",
                  "    pm.environment.set('userId', response[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "description": "Admin-only. Returns 403 if called with a standard User's token — useful for the second half of the RBAC test."
          },
          "response": []
        },
        {
          "name": "List All Users (as standard User - expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 403 Forbidden', function () {",
                  "    pm.response.to.have.status(403);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{secondAuthToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "description": "Run 'Register (Second User)' first so {{secondAuthToken}} is populated. Confirms a standard User genuinely cannot access this Admin-only endpoint."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get Task Statuses",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks/statuses",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "statuses"]
            },
            "description": "Returns the valid task statuses (Todo, InProgress, Done) with their IDs — use one of these IDs as 'statusId' in the Create/Update requests below."
          },
          "response": []
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const response = pm.response.json();",
                  "if (response.id) {",
                  "    pm.environment.set('taskId', response.id);",
                  "    console.log('taskId saved:', response.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Write the README\",\n  \"description\": \"Cover setup instructions and design decisions\",\n  \"statusId\": 1,\n  \"dueDate\": \"2026-08-01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            },
            "description": "Creates a task owned by the currently logged-in user. Saves the returned id to {{taskId}} for use by the requests below."
          },
          "response": []
        },
        {
          "name": "Create Task (Admin assigns to another user)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Review PR #12\",\n  \"description\": \"\",\n  \"statusId\": 1,\n  \"dueDate\": \"2026-07-20\",\n  \"ownerId\": \"{{userId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            },
            "description": "Only takes effect if the caller is an Admin — {{userId}} is populated by 'List All Users'. A standard User sending an ownerId is silently ignored server-side; the task is always assigned to themselves regardless."
          },
          "response": []
        },
        {
          "name": "Get Task By Id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            },
            "description": "Returns 404 if the task doesn't exist, 403 if it exists but the caller is neither the owner nor an Admin."
          },
          "response": []
        },
        {
          "name": "List Tasks (paginated)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            },
            "description": "Returns paginated tasks scoped to the current user; Admins see all tasks unless filtered."
          },
          "response": []
        },
        {
          "name": "List Tasks (filter by status)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks?page=1&pageSize=10&statusId=1",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" },
                { "key": "statusId", "value": "1" }
              ]
            },
            "description": "statusId=1 is Todo, 2 is InProgress, 3 is Done (confirm via 'Get Task Statuses')."
          },
          "response": []
        },
        {
          "name": "List Tasks (Admin filter by owner)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks?page=1&pageSize=10&ownerId={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" },
                { "key": "ownerId", "value": "{{userId}}" }
              ]
            },
            "description": "Admin-only capability — ignored server-side if called with a standard User's token, who is always scoped to their own tasks regardless of this parameter."
          },
          "response": []
        },
        {
          "name": "List Tasks (as second user - expect only their own)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('A standard User never sees the Admin task created earlier', function () {",
                  "    const response = pm.response.json();",
                  "    const taskId = pm.environment.get('taskId');",
                  "    const found = response.items.some(t => t.id === taskId);",
                  "    pm.expect(found).to.eql(false);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{secondAuthToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "pageSize", "value": "10" }
              ]
            },
            "description": "The key RBAC proof: run this with the second (standard User) token and confirm the Admin's task from earlier never appears in the list."
          },
          "response": []
        },
        {
          "name": "Get Another User's Task By Id (expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 403 Forbidden', function () {",
                  "    pm.response.to.have.status(403);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{secondAuthToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            },
            "description": "{{taskId}} belongs to the Admin. A standard User attempting to fetch it directly by ID should be blocked with 403, not just hidden from the list view."
          },
          "response": []
        },
        {
          "name": "Update Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 204 No Content', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Write the README\",\n  \"description\": \"Cover setup instructions, design decisions, and assumptions\",\n  \"statusId\": 2,\n  \"dueDate\": \"2026-08-05\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            },
            "description": "Moves the task to InProgress (statusId 2). Triggers a SignalR TaskUpdated broadcast to any connected clients."
          },
          "response": []
        },
        {
          "name": "Create Task (Validation Failure - expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 Bad Request', function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"\",\n  \"description\": \"\",\n  \"statusId\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"]
            },
            "description": "Empty title and invalid statusId should trigger FluentValidation and return field-level 400 errors."
          },
          "response": []
        },
        {
          "name": "Delete Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 204 No Content', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            },
            "description": "Triggers a SignalR TaskDeleted broadcast. Run 'Get Task By Id' again afterward to confirm it now returns 404."
          },
          "response": []
        },
        {
          "name": "Get Task By Id (after delete - expect 404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 404 Not Found', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["tasks", "{{taskId}}"]
            },
            "description": "Confirms the delete actually took effect."
          },
          "response": []
        }
      ]
    }
  ]
}
